# Deployer key (funded with Fuji testnet AVAX). Never commit the real value.
PRIVATE_KEY=

# RPC endpoints (referenced by foundry.toml [rpc_endpoints])
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Snowtrace/Routescan verification. "verifyContract" works with the RouteScan proxy.
SNOWTRACE_API_KEY=verifyContract

# Circuit-breaker thresholds consumed by Deploy.s.sol (values are in wei / bps).
MAX_TVL=1000000000000000000000000
MAX_MINT_PER_BLOCK=100000000000000000000000
MAX_PRICE_DEVIATION_BPS=500

# Optional overrides for TriggerDemo.s.sol (default to the live Fuji deployment).
BREAKER_ADDRESS=0x6110d2E081219a50c13E2bbCF4aD84725dEF1A5a
VAULT_ADDRESS=0x6394B314E3879aA4e02B9174F8697B04189452fc
